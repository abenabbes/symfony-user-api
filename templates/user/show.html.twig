{% extends 'base.html.twig' %}

{% block title %}Détail — {{ user.name }}{% endblock %}

{% block body %}
<style>
    .container { margin: 2em auto; max-width: 700px; width: 95%; font: 16px/1.5 sans-serif; }
    .card { border: 1px solid #ddd; border-radius: 8px; padding: 2em; margin-top: 1em; }
    .card h2 { margin-top: 0; color: #4A90E2; }
    .field { margin-bottom: 1em; }
    .label { font-weight: bold; color: #555; min-width: 120px; display: inline-block; }
    .badge-active { background: #28a745; color: white; padding: 2px 8px; border-radius: 10px; font-size: 12px; }
    .badge-inactive { background: #dc3545; color: white; padding: 2px 8px; border-radius: 10px; font-size: 12px; }
    .btn { padding: 8px 16px; border-radius: 4px; text-decoration: none; font-size: 14px; margin-right: 8px; }
    .btn-secondary { background: #6c757d; color: white; }
</style>

<div class="container">
    <h1>👤 Détail utilisateur</h1>

    <div class="card">
        <h2>{{ user.name }}</h2>

        <div class="field">
            <span class="label">ID :</span>
            {{ user.id }}
        </div>

        <div class="field">
            <span class="label">Nom :</span>
            {{ user.name }}
        </div>

        <div class="field">
            <span class="label">Age :</span>
            {{ user.age }} ans
        </div>

        <div class="field">
            <span class="label">Email :</span>
            {{ user.email }}
        </div>

        <div class="field">
            <span class="label">Statut :</span>
            {% if user.active %}
                <span class="badge-active">Actif</span>
            {% else %}
                <span class="badge-inactive">Inactif</span>
            {% endif %}
        </div>

        <div class="field">
            <span class="label">Créé le :</span>
            {{ user.createdAt ? user.createdAt|date('d/m/Y à H:i') : '-' }}
        </div>

        {% if user.address %}
        <div class="field">
            <span class="label">Adresse :</span>
            {{ user.address.street }}, {{ user.address.city }}, {{ user.address.country }}
        </div>
        {% endif %}
    </div>

    <br>
    <a href="{{ path('app_user_list') }}" class="btn btn-secondary">
        ← Retour à la liste
    </a>
</div>
{% endblock %}